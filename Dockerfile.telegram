FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
COPY packages/ packages/
COPY apps/ apps/

# Lean install — the bridge only needs python-telegram-bot + httpx + a tiny
# Starlette health surface, none of the heavy ML deps (fastembed/onnxruntime).
RUN uv sync --package mesh-telegram --no-dev

CMD ["uv", "run", "mesh-telegram"]
