# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Database
MESH_DB_PATH=./data/mesh.db

# LLM provider — "anthropic" (default, cloud), "ollama" (local), or "groq"
# (cloud, open-weight models)
MESH_LLM_PROVIDER=anthropic

# Model — must match the provider:
#   anthropic: claude-haiku-4-5 (default), claude-sonnet-4-6, claude-opus-4-7
#   ollama:    qwen3:8b (default), llama3.1:8b, etc.
#   groq:      openai/gpt-oss-120b (default), qwen/qwen3-32b, etc.
# NOTE: setting this pins EVERY agent and bypasses Phase 20 routing below.
# Comment it out to use the tiered-routing recipe.
MESH_LLM_MODEL=claude-haiku-4-5

# Anthropic API key — required when MESH_LLM_PROVIDER=anthropic.
# Get one at https://console.anthropic.com (set a low monthly spend cap).
ANTHROPIC_API_KEY=

# Groq API key — required when MESH_LLM_PROVIDER=groq or when routing's cheap
# tier is Groq. Get one at https://console.groq.com/keys.
GROQ_API_KEY=
# Optional override for OpenAI-compatible proxies (default is Groq's API):
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama — only used when MESH_LLM_PROVIDER=ollama.
OLLAMA_HOST=http://localhost:11434

# ── Phase 20: tiered model routing (OFF by default) ──────────────────────────
# A router sends the bulk of traffic to a cheap tier and escalates the hard or
# failed cases to a strong tier. Purely additive and opt-in per agent; with the
# block below commented out the system behaves exactly as today.
#
# IMPORTANT: a static model pin bypasses routing. MESH_LLM_MODEL above (and
# MESH_LLM_MODEL_DEFAULT / MESH_LLM_MODEL_<AGENT>) is an explicit operator pin
# and wins over routing. To let an agent route, leave its model unpinned.
#
# Recommended recipe — cheap=GPT-OSS-120B on Groq (~7x cheaper than Haiku,
# similar latency), strong=Haiku 4.5 on Anthropic. Long/dense inputs, hinted
# requests, and cheap-tier parse failures escalate to Haiku. Needs
# GROQ_API_KEY above and MESH_LLM_MODEL commented out:
# MESH_ROUTE_ENABLED=true
# MESH_ROUTE_CHEAP_PROVIDER=groq
# MESH_ROUTE_CHEAP_MODEL=openai/gpt-oss-120b
# MESH_ROUTE_STRONG_PROVIDER=anthropic
# MESH_ROUTE_STRONG_MODEL=claude-haiku-4-5
#
# All-Anthropic alternative — cheap=Haiku 4.5, strong=Sonnet 4.6, routing only
# the high-volume, input-size-variance agents:
# MESH_ROUTE_ENABLED=true
# MESH_ROUTE_CHEAP_MODEL=claude-haiku-4-5
# MESH_ROUTE_STRONG_MODEL=claude-sonnet-4-6
# MESH_ROUTE_EXTRACTION_ENABLED=true
# MESH_ROUTE_SKEPTIC_ENABLED=true
# MESH_ROUTE_ENTITY_RESOLUTION_ENABLED=true
#
# Escalate to the strong tier when user content reaches this many characters:
# MESH_ROUTE_ESCALATE_CHARS=12000
# Retry once on the strong tier when the cheap tier fails to parse (default on):
# MESH_ROUTE_ESCALATE_ON_PARSE_FAIL=true
# Retry once on the strong tier when the cheap tier is rate-limited (default on
# — keeps the pipeline at full pace at the strong tier's price when e.g. the
# Groq free tier throttles):
# MESH_ROUTE_ESCALATE_ON_RATE_LIMIT=true
# Optional: per-agent strong-model override (skeptic escalates to Opus):
# MESH_LLM_MODEL_SKEPTIC_STRONG=claude-opus-4-8

# Belief consolidation (Phase 19) — semantic dedup/merge + staleness decay.
# Conservative defaults; tighter bands than entity resolution.
# MESH_BELIEF_MERGE_HIGH=0.95
# MESH_BELIEF_MERGE_LOW=0.85
# MESH_BELIEF_CANDIDATE_LIMIT=500
# MESH_BELIEF_DECAY_HALFLIFE_DAYS=90
# MESH_BELIEF_DECAY_FLOOR=0.1
# MESH_BELIEF_ARCHIVE_AFTER_DAYS=365
# MESH_BELIEF_CONSOLIDATION_BATCH=true
# MESH_LLM_MODEL_BELIEF_CONSOLIDATOR=claude-haiku-4-5

# Phase 22: autonomous discovery (`mesh-discover` / `make discover`). The sweep
# analyzes each active field for gaps/trends, opens `origin=discovery`
# investigations, and dispatches real hypothesis-directed search. Bounded:
# MESH_DISCOVER_MAX_NEW=5
# MESH_DISCOVER_MAX_FETCH=10
# MESH_DISCOVER_GAP_LIMIT=20
# Scope the sweep to one field (default: all active fields):
# MESH_DISCOVER_FIELD=ai-robotics
# Pin (or route) the hypothesis-drafting model:
# MESH_LLM_MODEL_DISCOVERY=claude-haiku-4-5

# ── Daily LLM budget brake (both unset = off) ────────────────────────────────
# When today's (UTC) llm_usage ledger reaches either limit, the controller
# defers LLM-bound skills until the day rolls over; LLM-free work (scouting,
# synthesis, maintenance) continues and nothing is lost — deferred tensions
# simply re-plan tomorrow. Pin the token knob to your cheap provider's free
# daily quota (e.g. 950000 ≈ Cerebras's 1M tokens/day, with margin) and the
# mesh lives inside the free tier; the USD knob is a hard spend ceiling.
# MESH_DAILY_LLM_BUDGET_TOKENS=950000
# MESH_DAILY_LLM_BUDGET_USD=1.50

# Pipeline defaults
MESH_PIPELINE_CATEGORIES=cs.AI,cs.RO,cs.LG
MESH_PIPELINE_MAX_PAPERS=20
MESH_PIPELINE_CONCURRENCY=3

# HN scout — comma-separated keywords for Algolia HN Search
MESH_HN_KEYWORDS=AI,LLM,GPT,Claude,robotics,RAG,agent

# GitHub scout — comma-separated topic strings and watchlist of owner/repo
# slugs whose releases.atom feed will be polled each run.
MESH_GITHUB_TOPICS=llm,agents,machine-learning,ai,robotics
MESH_GITHUB_WATCHLIST=
# Optional GitHub PAT raises the public 60 req/hr rate limit to 5000/hr; the
# scout works unauthenticated but is much slower on first warm-up.
GITHUB_TOKEN=

# Bluesky scout — public AppView API, no auth needed for read.
MESH_BLUESKY_HASHTAGS=ai,ml,llm
# Optional curated handles whose author feeds get pulled (e.g. researcher accounts).
MESH_BLUESKY_HANDLES=

# Reddit scout — top posts per sub. Requires OAuth2 client credentials
# (create at https://www.reddit.com/prefs/apps -> "script" type).
# Without these, the scout returns empty and the rest of the pipeline keeps
# running.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
MESH_REDDIT_SUBS=MachineLearning,LocalLLaMA,singularity,artificial

# Blog scout — RSS/Atom-based, no auth. Override the default feed list via
# either of:
#   MESH_BLOG_FEEDS=https://feed1,https://feed2     (comma-separated URLs)
#   MESH_BLOG_FEEDS_FILE=/path/to/blog_feeds.yaml   (same shape as config/blog_feeds.yaml)
# If neither is set, the agent loads config/blog_feeds.yaml from the repo.
MESH_BLOG_FEEDS=
MESH_BLOG_FEEDS_FILE=
# Entries older than this window are skipped each run.
MESH_BLOG_LOOKBACK_HOURS=24

# Phase 18a: config-driven connectors (web_search / rss / rest_json). These are
# generic catalog connectors a field enables with its own config — not seeded
# into ai-robotics. Only web_search needs a key:
# Brave Search API key for the web_search connector. Get one at
# https://api-dashboard.search.brave.com. Without it the connector returns
# empty (the rest of the pipeline keeps running). The rss/rest_json connectors
# fetch user-supplied URLs and need no key.
BRAVE_API_KEY=

# Phase 2: A2A distributed mode
# Set MESH_USE_A2A=1 to route pipeline through A2A agent servers instead of in-process
MESH_USE_A2A=
# Comma-separated base URLs of running A2A agent servers
MESH_AGENT_URLS=http://localhost:8001,http://localhost:8002,http://localhost:8003,http://localhost:8004,http://localhost:8005,http://localhost:8008,http://localhost:8009,http://localhost:8010,http://localhost:8011,http://localhost:8012

# A2A agent server settings (used when running individual agent servers)
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_PUBLIC_URL=http://localhost:8000

# Phase 4: Falsification loop (`make skeptic`) — Curator + Skeptic + sweep job.
# Per-agent model override for the Skeptic. Leave unset to inherit
# MESH_LLM_MODEL_DEFAULT then the provider default.
MESH_LLM_MODEL_SKEPTIC=
# Phase 5c: Personalizer model — Sonnet is the recommended default for the
# briefing pass; Haiku may not have enough reasoning headroom for nuanced
# relevance scoring.
MESH_LLM_MODEL_PERSONALIZER=claude-sonnet-4-6
# Profile that drives /briefing personalization. Default location is
# ~/.config/agent_mesh/profile.md; override with an absolute path.
MESH_PROFILE_PATH=
# Apply a Skeptic assessment only if its self-reported confidence clears this.
MESH_SKEPTIC_APPLY_THRESHOLD=0.7
# How many beliefs the Curator returns per sweep.
MESH_CURATOR_PICK_COUNT=5
# Curator score penalty window for beliefs the Skeptic just looked at.
MESH_CURATOR_COOLDOWN_DAYS=7
# reliability_prior assigned to the synthetic agent_reasoning Source rows
# the Skeptic emits to anchor its counter-claims.
MESH_SKEPTIC_SOURCE_RELIABILITY=0.4
# Comma-separated A2A base URLs the skeptic-sweep orchestrator discovers.
MESH_SKEPTIC_AGENT_URLS=http://curator:8007,http://skeptic:8006

# Phase 5a: Task-based A2A dispatch.
# Orchestrators submit work then poll GET /mesh/tasks/{task_id} until
# the agent reports completed/failed. Each poll cycle waits this long.
MESH_TASK_POLL_INTERVAL_SECONDS=0.5
# Fallback timeout (seconds) used when no MESH_TASK_TIMEOUT_<SKILL> override is set.
MESH_TASK_TIMEOUT_DEFAULT=120
# Per-skill timeouts. LLM-bound skills are slow; scouts are fast. Examples:
# MESH_TASK_TIMEOUT_EXTRACT_CLAIMS=180
# MESH_TASK_TIMEOUT_CHALLENGE_BELIEF=180
# MESH_TASK_TIMEOUT_SCOUT_ARXIV=60
# MESH_TASK_TIMEOUT_RESOLVE_ENTITIES=30

# Curator weight for "no fresh supporting/contradicting claim arrived in a
# while" — additive on top of last_revised_at-based age. No claims → max.
MESH_CURATOR_STALENESS_WEIGHT=0.3

# Phase 8: seconds a non-finalized run's latest LangGraph checkpoint can age
# before the /status page flags the run as interrupted.
MESH_TASK_RESUME_THRESHOLD=600

# Phase 6b: Tailscale-only access. Leave empty for local dev — services
# bind to 0.0.0.0. Set to the host's tailnet IP (100.x.x.x or similar) to
# bind API + wiki + status page only on the Tailscale interface.
MESH_BIND_INTERFACE=

# Phase 8: LangGraph checkpoint store (Postgres). The compose stack runs a
# dedicated `langgraph-db` container and injects LANGGRAPH_POSTGRES_URL into
# the coordinator, skeptic-sweep, scheduler, and api services automatically;
# you normally only override the password. When LANGGRAPH_POSTGRES_URL is
# unset (e.g. local `uv run` / tests), the graphs fall back to an in-memory
# checkpointer, so no Postgres is required outside Docker.
LANGGRAPH_POSTGRES_PASSWORD=langgraph
# LANGGRAPH_POSTGRES_URL=postgresql://langgraph:langgraph@localhost:5432/langgraph

# ── Telegram bridge (apps/telegram, service: telegram-bot) ───────────────────
# Chat with the mesh and receive the daily brief from the Telegram app.
# Long-polling, so no public URL / inbound port is needed — runs behind NAT.
#
# 1) Create a bot with @BotFather in Telegram, copy the token here.
TELEGRAM_BOT_TOKEN=
# 2) Allow-list the chat ids that may use the bot + receive the daily brief
#    (comma-separated). Leave empty at first: message the bot and it replies
#    with your chat id, then paste it here and restart the service. A non-empty
#    allow-list is required — an empty one authorizes no one (the bot is
#    discoverable by username, so this keeps strangers out of your mesh).
TELEGRAM_ALLOWED_CHAT_IDS=
# Daily brief push: on/off, and the time of day it fires (in TELEGRAM_TZ).
TELEGRAM_BRIEFING_ENABLED=true
TELEGRAM_BRIEFING_HOUR=13
TELEGRAM_BRIEFING_MINUTE=0
# IANA tz name (e.g. America/Vancouver); defaults to UTC if blank/unknown.
TELEGRAM_TZ=UTC
# Field the bot scopes chat + briefs to.
MESH_TELEGRAM_FIELD=ai-robotics
# Optional: public wiki base URL so brief items link to their detail pages
# (e.g. http://<pi-tailnet-name>:3000). Leave blank to show bare ids.
MESH_TELEGRAM_WIKI_URL=

# --- User control: admin/beta roles + beta chatbot quota (security phase) ---
# Admin is a property of the running WIKI INSTANCE, not of the client — nothing
# the browser sends can grant it, so there is no token to guess or leak. Run the
# wiki with MESH_ADMIN_MODE=true on a local / non-exposed instance to be admin
# there; leave it OFF on the public deployment, which is then beta-only
# (anonymous, view-only, rate-limited chat) with no path to admin at all. On an
# admin instance the owner can preview the beta experience from the nav.
#
# Wiki only — set to true ONLY on a non-public instance to grant admin. Off (the
# default) = beta-only. DO NOT enable on a publicly reachable instance.
MESH_ADMIN_MODE=
# Wiki + API (same value) — lets ONLY the wiki server call privileged API
# endpoints (create/patch topic, connector toggle, schedule, trigger) and the
# rate-limited /ask. Unset on the API = guard disabled (dev/local posture).
MESH_INTERNAL_TOKEN=
# API only — grounded questions an anonymous beta browser may ask per day.
MESH_BETA_DAILY_QUERY_LIMIT=3
