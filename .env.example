# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Database
MESH_DB_PATH=./data/mesh.db

# Ollama
OLLAMA_HOST=http://localhost:11434

# LLM model (defaults to qwen3:14b; use qwen3:8b for lower-memory setups)
MESH_LLM_MODEL=qwen3:14b

# Pipeline defaults
MESH_PIPELINE_CATEGORIES=cs.AI,cs.RO,cs.LG
MESH_PIPELINE_MAX_PAPERS=20
MESH_PIPELINE_CONCURRENCY=3
