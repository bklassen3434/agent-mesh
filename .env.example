# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Database
MESH_DB_PATH=./data/mesh.db

# LLM provider — "anthropic" (default, cloud) or "ollama" (local)
MESH_LLM_PROVIDER=anthropic

# Model — must match the provider:
#   anthropic: claude-haiku-4-5 (default), claude-sonnet-4-6, claude-opus-4-7
#   ollama:    qwen3:8b (default), llama3.1:8b, etc.
MESH_LLM_MODEL=claude-haiku-4-5

# Anthropic API key — required when MESH_LLM_PROVIDER=anthropic.
# Get one at https://console.anthropic.com (set a low monthly spend cap).
ANTHROPIC_API_KEY=

# Ollama — only used when MESH_LLM_PROVIDER=ollama.
OLLAMA_HOST=http://localhost:11434

# Pipeline defaults
MESH_PIPELINE_CATEGORIES=cs.AI,cs.RO,cs.LG
MESH_PIPELINE_MAX_PAPERS=20
MESH_PIPELINE_CONCURRENCY=3

# HN scout — comma-separated keywords for Algolia HN Search
MESH_HN_KEYWORDS=AI,LLM,GPT,Claude,robotics,RAG,agent

# GitHub scout — comma-separated topic strings and watchlist of owner/repo
# slugs whose releases.atom feed will be polled each run.
MESH_GITHUB_TOPICS=llm,agents,machine-learning,ai,robotics
MESH_GITHUB_WATCHLIST=
# Optional GitHub PAT raises the public 60 req/hr rate limit to 5000/hr; the
# scout works unauthenticated but is much slower on first warm-up.
GITHUB_TOKEN=

# Bluesky scout — public AppView API, no auth needed for read.
MESH_BLUESKY_HASHTAGS=ai,ml,llm
# Optional curated handles whose author feeds get pulled (e.g. researcher accounts).
MESH_BLUESKY_HANDLES=

# Reddit scout — top posts per sub. Requires OAuth2 client credentials
# (create at https://www.reddit.com/prefs/apps -> "script" type).
# Without these, the scout returns empty and the rest of the pipeline keeps
# running.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
MESH_REDDIT_SUBS=MachineLearning,LocalLLaMA,singularity,artificial

# Blog scout — RSS/Atom-based, no auth. Override the default feed list via
# either of:
#   MESH_BLOG_FEEDS=https://feed1,https://feed2     (comma-separated URLs)
#   MESH_BLOG_FEEDS_FILE=/path/to/blog_feeds.yaml   (same shape as config/blog_feeds.yaml)
# If neither is set, the agent loads config/blog_feeds.yaml from the repo.
MESH_BLOG_FEEDS=
MESH_BLOG_FEEDS_FILE=
# Entries older than this window are skipped each run.
MESH_BLOG_LOOKBACK_HOURS=24

# Phase 2: A2A distributed mode
# Set MESH_USE_A2A=1 to route pipeline through A2A agent servers instead of in-process
MESH_USE_A2A=
# Comma-separated base URLs of running A2A agent servers
MESH_AGENT_URLS=http://localhost:8001,http://localhost:8002,http://localhost:8003,http://localhost:8004,http://localhost:8005,http://localhost:8008,http://localhost:8009,http://localhost:8010,http://localhost:8011,http://localhost:8012

# A2A agent server settings (used when running individual agent servers)
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_PUBLIC_URL=http://localhost:8000

# Phase 4: Falsification loop (`make skeptic`) — Curator + Skeptic + sweep job.
# Per-agent model override for the Skeptic. Leave unset to inherit
# MESH_LLM_MODEL_DEFAULT then the provider default.
MESH_LLM_MODEL_SKEPTIC=
# Phase 5c: Personalizer model — Sonnet is the recommended default for the
# briefing pass; Haiku may not have enough reasoning headroom for nuanced
# relevance scoring.
MESH_LLM_MODEL_PERSONALIZER=claude-sonnet-4-6
# Profile that drives /briefing personalization. Default location is
# ~/.config/agent_mesh/profile.md; override with an absolute path.
MESH_PROFILE_PATH=
# Apply a Skeptic assessment only if its self-reported confidence clears this.
MESH_SKEPTIC_APPLY_THRESHOLD=0.7
# How many beliefs the Curator returns per sweep.
MESH_CURATOR_PICK_COUNT=5
# Curator score penalty window for beliefs the Skeptic just looked at.
MESH_CURATOR_COOLDOWN_DAYS=7
# reliability_prior assigned to the synthetic agent_reasoning Source rows
# the Skeptic emits to anchor its counter-claims.
MESH_SKEPTIC_SOURCE_RELIABILITY=0.4
# Comma-separated A2A base URLs the skeptic-sweep orchestrator discovers.
MESH_SKEPTIC_AGENT_URLS=http://curator:8007,http://skeptic:8006

# Phase 5a: Task-based A2A dispatch.
# Orchestrators submit work then poll GET /mesh/tasks/{task_id} until
# the agent reports completed/failed. Each poll cycle waits this long.
MESH_TASK_POLL_INTERVAL_SECONDS=0.5
# Fallback timeout (seconds) used when no MESH_TASK_TIMEOUT_<SKILL> override is set.
MESH_TASK_TIMEOUT_DEFAULT=120
# Per-skill timeouts. LLM-bound skills are slow; scouts are fast. Examples:
# MESH_TASK_TIMEOUT_EXTRACT_CLAIMS=180
# MESH_TASK_TIMEOUT_CHALLENGE_BELIEF=180
# MESH_TASK_TIMEOUT_SCOUT_ARXIV=60
# MESH_TASK_TIMEOUT_RESOLVE_ENTITIES=30

# Phase 6a: APScheduler-managed cadence.
# Cron expressions for the in-process scheduler service (compose profile
# "scheduler"). Defaults: pipeline every 6h on the hour, sweep daily at 03:00.
MESH_SCHEDULE_PIPELINE_CRON=0 */6 * * *
MESH_SCHEDULE_SWEEP_CRON=0 3 * * *
# Curator weight for "no fresh supporting/contradicting claim arrived in a
# while" — additive on top of last_revised_at-based age. No claims → max.
MESH_CURATOR_STALENESS_WEIGHT=0.3
